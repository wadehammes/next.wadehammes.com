{
  "name": "next-wade-hammes",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev -p 4431 --webpack",
    "build": "next build --webpack && make sitemap ",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start -p 4431",
    "export": "next export",
    "tsc:ci": "tsc --strict",
    "lint": "biome check",
    "lint:ci": "biome ci --reporter=github",
    "lint:fix": "biome check --fix",
    "lint:changed": "biome check --changed --since origin/main --no-errors-on-unmatched --verbose --write --diagnostic-level=error",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "lint:all": "pnpm lint:changed && pnpm lint:css:fix",
    "test:ci": "jest --passWithNoTests",
    "types:prismic": "node scripts/prismic-codegen.cjs",
    "types:prismic:cli": "prismic-ts-codegen",
    "knip": "knip",
    "knip:ci": "knip --no-progress"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.10",
    "@prismicio/client": "^7.21.8",
    "@prismicio/next": "^2.3.0",
    "@prismicio/react": "^3.4.1",
    "@svgr/webpack": "^8.1.0",
    "@types/webpack": "^5.28.5",
    "classnames": "^2.5.1",
    "culori": "^4.0.2",
    "gsap": "^3.15.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intersection-observer": "^10.1.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@faker-js/faker": "^10.5.0",
    "@jest/globals": "^30.4.1",
    "@jest/types": "^30.4.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@prismicio/types": "^0.2.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "dotenv": "^17.4.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.25.0",
    "prismic-ts-codegen": "^0.1.30",
    "stylelint": "^17.14.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "typescript": "^6.0.3"
  }
}
